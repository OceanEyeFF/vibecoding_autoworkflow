{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Route Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_type",
    "goal",
    "read_first",
    "read_next",
    "code_entry",
    "do_not_read_yet",
    "stop_reading_when",
    "scope_hint",
    "verification_entry",
    "optional_background",
    "open_questions"
  ],
  "properties": {
    "task_type": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "read_first": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "read_next": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "code_entry": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "do_not_read_yet": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stop_reading_when": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope_hint": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_entry": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "optional_background": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
