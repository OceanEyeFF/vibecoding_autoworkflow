      "items": {
        "type": "string"
      }
    },
    "cleanup_targets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks_left": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_basis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "write_to_exploratory_records": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "followups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "docs_to_sync": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes_for_next_round": {
      "type": "array",
      "items": {
        "type": "string"
      }
