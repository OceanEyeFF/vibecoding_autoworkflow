    "non_changes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "write_to_core_truth": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "write_to_operational_truth": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
