{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Autoresearch Feedback Distill",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feedback_distill_version",
    "run_id",
    "round",
    "mutation_key",
    "mutation_id",
    "attempt",
    "decision",
    "train_score_delta",
    "validation_score_delta",
    "parse_error_delta",
    "timeout_rate_delta",
    "signal_strength",
    "regression_flags",
    "dimension_feedback_summary",
    "suggested_adjustments",
    "scoreboard_ref",
    "decision_ref",
    "worker_contract_ref",
    "distilled_at"
  ],
  "properties": {
    "feedback_distill_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "mutation_key": {
      "type": "string",
      "minLength": 1
    },
    "mutation_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "keep",
        "discard"
      ]
    },
    "train_score_delta": {
      "type": "number"
    },
    "validation_score_delta": {
      "type": "number"
    },
    "parse_error_delta": {
      "type": "number"
    },
    "timeout_rate_delta": {
      "type": "number"
    },
    "signal_strength": {
      "type": "string",
      "enum": [
        "positive",
        "mixed",
        "negative"
      ]
    },
    "regression_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dimension_feedback_summary": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "suggested_adjustments": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scoreboard_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "worker_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "distilled_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
