{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Autoresearch Worker Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "worker_contract_version",
    "run_id",
    "round",
    "mutation_id",
    "mutation_key",
    "attempt",
    "fingerprint",
    "kind",
    "instruction",
    "target_paths",
    "allowed_actions",
    "guardrails",
    "expected_effect",
    "base_sha",
    "candidate_branch",
    "candidate_worktree",
    "agent_report_path",
    "mutation_path",
    "contract_path",
    "mutation_sha256"
  ],
  "properties": {
    "worker_contract_version": {
      "type": "integer",
      "minimum": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "mutation_id": {
      "type": "string",
      "minLength": 1
    },
    "mutation_key": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "target_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_non_empty_diff",
        "max_files_touched",
        "extra_frozen_paths"
      ],
      "properties": {
        "require_non_empty_diff": {
          "type": "boolean"
        },
        "max_files_touched": {
          "type": "integer",
          "minimum": 1
        },
        "extra_frozen_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "expected_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis",
        "primary_metrics",
        "guard_metrics"
      ],
      "properties": {
        "hypothesis": {
          "type": "string",
          "minLength": 1
        },
        "primary_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "guard_metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "base_sha": {
      "type": "string",
      "minLength": 1
    },
    "candidate_branch": {
      "type": "string",
      "minLength": 1
    },
    "candidate_worktree": {
      "type": "string",
      "minLength": 1
    },
    "agent_report_path": {
      "type": "string",
      "minLength": 1
    },
    "mutation_path": {
      "type": "string",
      "minLength": 1
    },
    "contract_path": {
      "type": "string",
      "minLength": 1
    },
    "mutation_sha256": {
      "type": "string",
      "minLength": 1
    },
    "baseline_summary": {
      "type": "object"
    },
    "previous_feedback_excerpt": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        }
      ]
    },
    "authority_note": {
      "type": "string"
    }
  }
}

