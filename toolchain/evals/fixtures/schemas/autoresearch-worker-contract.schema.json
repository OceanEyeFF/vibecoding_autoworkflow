{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Autoresearch Worker Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "worker_contract_version",
    "run_id",
    "round",
    "mutation_id",
    "mutation_key",
    "attempt",
    "base_sha",
    "candidate_branch",
    "candidate_worktree",
    "agent_report_path",
    "target_paths",
    "allowed_actions",
    "guardrails",
    "instruction",
    "expected_effect",
    "objective",
    "target_surface",
    "comparison_baseline",
    "recent_feedback_excerpt",
    "contract_fingerprint",
    "mutation_fingerprint",
    "materialized_at"
  ],
  "properties": {
    "worker_contract_version": {
      "type": "integer",
      "const": 2
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "mutation_id": {
      "type": "string",
      "minLength": 1
    },
    "mutation_key": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "base_sha": {
      "type": "string",
      "minLength": 1
    },
    "candidate_branch": {
      "type": "string",
      "minLength": 1
    },
    "candidate_worktree": {
      "type": "string",
      "minLength": 1
    },
    "agent_report_path": {
      "type": "string",
      "minLength": 1
    },
    "target_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "guardrails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_non_empty_diff",
        "max_files_touched",
        "extra_frozen_paths"
      ],
      "properties": {
        "require_non_empty_diff": {
          "type": "boolean"
        },
        "max_files_touched": {
          "type": "integer",
          "minimum": 1
        },
        "extra_frozen_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "instruction": {
      "type": "string",
      "minLength": 1
    },
    "expected_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hypothesis",
        "primary_metrics",
        "guard_metrics"
      ],
      "properties": {
        "hypothesis": {
          "type": "string",
          "minLength": 1
        },
        "primary_metrics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "guard_metrics": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "target_surface": {
      "type": "string",
      "minLength": 1
    },
    "comparison_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "train_score",
        "validation_score"
      ],
      "properties": {
        "train_score": {
          "type": [
            "number",
            "null"
          ]
        },
        "validation_score": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "recent_feedback_excerpt": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contract_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "mutation_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "materialized_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
