{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Autoresearch Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "label",
    "objective",
    "target_surface",
    "mutable_paths",
    "frozen_paths",
    "train_suites",
    "validation_suites",
    "acceptance_suites",
    "primary_metrics",
    "guard_metrics",
    "qualitative_veto_checks",
    "max_rounds",
    "max_candidate_attempts_per_round",
    "timeout_policy",
    "promotion_policy"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "target_surface": {
      "type": "string",
      "minLength": 1
    },
    "mutable_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "frozen_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "train_suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "validation_suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_suites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "primary_metrics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "guard_metrics": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "qualitative_veto_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "max_rounds": {
      "type": "integer",
      "minimum": 1
    },
    "max_candidate_attempts_per_round": {
      "type": "integer",
      "minimum": 1
    },
    "timeout_policy": {
      "type": "object"
    },
    "promotion_policy": {
      "type": "object"
    }
  }
}
