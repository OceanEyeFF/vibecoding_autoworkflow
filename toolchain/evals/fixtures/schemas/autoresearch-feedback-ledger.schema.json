{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Autoresearch Feedback Ledger Entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feedback_ledger_version",
    "run_id",
    "round",
    "mutation_key",
    "mutation_id",
    "attempt",
    "decision",
    "train_score_delta",
    "validation_score_delta",
    "parse_error_delta",
    "timeout_rate_delta",
    "signal_strength",
    "regression_flags",
    "dimension_feedback_summary",
    "aggregate_prompt_guidance",
    "scoreboard_ref",
    "decision_ref",
    "worker_contract_ref",
    "distilled_at"
  ],
  "properties": {
    "feedback_ledger_version": {
      "type": "integer",
      "const": 2
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "mutation_key": {
      "type": "string",
      "minLength": 1
    },
    "mutation_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "keep",
        "discard"
      ]
    },
    "train_score_delta": {
      "type": "number"
    },
    "validation_score_delta": {
      "type": "number"
    },
    "parse_error_delta": {
      "type": "number"
    },
    "timeout_rate_delta": {
      "type": "number"
    },
    "signal_strength": {
      "type": "string",
      "enum": [
        "positive",
        "mixed",
        "negative"
      ]
    },
    "regression_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dimension_feedback_summary": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "aggregate_prompt_guidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aggregate_direction",
        "aggregate_suggested_adjustments",
        "top_regression_repos",
        "top_improvement_repos",
        "dominant_dimension_signals",
        "generation_status"
      ],
      "properties": {
        "aggregate_direction": {
          "type": "string",
          "enum": [
            "positive",
            "mixed",
            "negative"
          ]
        },
        "aggregate_suggested_adjustments": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "top_regression_repos": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "top_improvement_repos": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dominant_dimension_signals": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "dimension",
              "signal",
              "count",
              "repos"
            ],
            "properties": {
              "dimension": {
                "type": "string",
                "minLength": 1
              },
              "signal": {
                "type": "string",
                "enum": [
                  "improved",
                  "weaker"
                ]
              },
              "count": {
                "type": "integer",
                "minimum": 1
              },
              "repos": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "generation_status": {
          "type": "string",
          "enum": [
            "generated",
            "no_repo_guidance",
            "unsupported_task_only",
            "missing_baseline_only",
            "no_prior_feedback"
          ]
        }
      }
    },
    "scoreboard_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "worker_contract_ref": {
      "type": "string",
      "minLength": 1
    },
    "distilled_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
