{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Research Run Summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runner",
    "generated_at",
    "results"
  ],
  "properties": {
    "runner": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "suite_file": {
      "type": ["string", "null"]
    },
    "summary_schema": {
      "type": "string",
      "minLength": 1
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repo_path",
          "task",
          "phase",
          "backend",
          "judge_backend",
          "prompt_file",
          "returncode",
          "timed_out",
          "elapsed_seconds",
          "started_at",
          "finished_at",
          "artifacts"
        ],
        "properties": {
          "repo_path": {
            "type": "string",
            "minLength": 1
          },
          "task": {
            "type": "string",
            "minLength": 1
          },
          "phase": {
            "type": "string",
            "enum": ["skill", "eval"]
          },
          "backend": {
            "type": "string",
            "minLength": 1
          },
          "judge_backend": {
            "type": "string",
            "minLength": 1
          },
          "prompt_file": {
            "type": "string",
            "minLength": 1
          },
          "returncode": {
            "type": ["integer", "null"]
          },
          "timed_out": {
            "type": "boolean"
          },
          "elapsed_seconds": {
            "type": "number",
            "minimum": 0
          },
          "started_at": {
            "type": "string",
            "minLength": 1
          },
          "finished_at": {
            "type": "string",
            "minLength": 1
          },
          "schema_file": {
            "type": ["string", "null"]
          },
          "parse_error": {
            "type": ["string", "null"]
          },
          "failure_reason": {
            "type": ["string", "null"]
          },
          "attempt_count": {
            "type": "integer",
            "minimum": 1
          },
          "final_attempt": {
            "type": "integer",
            "minimum": 1
          },
          "attempts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "attempt",
                "returncode",
                "timed_out",
                "failure_reason",
                "parse_error",
                "raw_stdout_excerpt",
                "raw_stderr_excerpt",
                "started_at",
                "finished_at",
                "elapsed_seconds"
              ],
              "properties": {
                "attempt": {
                  "type": "integer",
                  "minimum": 1
                },
                "returncode": {
                  "type": ["integer", "null"]
                },
                "timed_out": {
                  "type": "boolean"
                },
                "failure_reason": {
                  "type": ["string", "null"]
                },
                "parse_error": {
                  "type": ["string", "null"]
                },
                "raw_stdout_excerpt": {
                  "type": ["string", "null"]
                },
                "raw_stderr_excerpt": {
                  "type": ["string", "null"]
                },
                "started_at": {
                  "type": "string",
                  "minLength": 1
                },
                "finished_at": {
                  "type": "string",
                  "minLength": 1
                },
                "elapsed_seconds": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          },
          "backend_context": {
            "type": "object",
            "additionalProperties": true
          },
          "structured_output": {
            "type": ["object", "null"]
          },
          "artifacts": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
