{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Eval Run Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_type",
    "manifest_version",
    "run_id",
    "run_dir",
    "started_at",
    "backend",
    "scenario_id",
    "skill",
    "title",
    "goal",
    "adapter_path",
    "program_path",
    "schema_path",
    "prompt_path",
    "stdout_path",
    "stderr_path",
    "response_path",
    "parsed_path",
    "command",
    "dry_run",
    "timeout_sec",
    "status"
  ],
  "properties": {
    "manifest_type": {
      "type": "string",
      "const": "run-manifest"
    },
    "manifest_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "backend": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": [
        "string",
        "null"
      ]
    },
    "fixture_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "skill": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "adapter_path": {
      "type": "string",
      "minLength": 1
    },
    "program_path": {
      "type": "string",
      "minLength": 1
    },
    "schema_path": {
      "type": "string",
      "minLength": 1
    },
    "prompt_path": {
      "type": "string",
      "minLength": 1
    },
    "stdout_path": {
      "type": "string",
      "minLength": 1
    },
    "stderr_path": {
      "type": "string",
      "minLength": 1
    },
    "response_path": {
      "type": "string",
      "minLength": 1
    },
    "parsed_path": {
      "type": "string",
      "minLength": 1
    },
    "score_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "dry_run": {
      "type": "boolean"
    },
    "timeout_sec": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "dry-run",
        "timeout",
        "failed",
        "invalid-output",
        "completed"
      ]
    },
    "exit_code": {
      "type": [
        "integer",
        "null"
      ]
    },
    "duration_sec": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "timeout_error": {
      "type": [
        "string",
        "null"
      ]
    },
    "response_bytes": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "json_parse_error": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
