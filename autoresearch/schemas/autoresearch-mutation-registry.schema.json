{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Autoresearch Mutation Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "registry_version", "contract_fingerprint", "entries"],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "registry_version": {
      "oneOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "string",
          "minLength": 1
        }
      ]
    },
    "contract_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mutation_key",
          "kind",
          "status",
          "target_paths",
          "allowed_actions",
          "instruction_seed",
          "expected_effect",
          "guardrails",
          "origin",
          "attempts",
          "last_selected_round",
          "last_decision"
        ],
        "properties": {
          "mutation_key": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["active", "disabled", "exhausted"]
          },
          "target_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "allowed_actions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "instruction_seed": {
            "type": "string",
            "minLength": 1
          },
          "expected_effect": {
            "type": "object",
            "additionalProperties": false,
            "required": ["hypothesis", "primary_metrics", "guard_metrics"],
            "properties": {
              "hypothesis": {
                "type": "string",
                "minLength": 1
              },
              "primary_metrics": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "guard_metrics": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "guardrails": {
            "type": "object",
            "additionalProperties": false,
            "required": ["require_non_empty_diff", "max_files_touched", "extra_frozen_paths"],
            "properties": {
              "require_non_empty_diff": {
                "type": "boolean"
              },
              "max_files_touched": {
                "type": "integer",
                "minimum": 1
              },
              "extra_frozen_paths": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "fingerprint_basis": {
            "type": "object"
          },
          "fingerprint": {
            "type": "string",
            "minLength": 1
          },
          "origin": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "ref"],
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              },
              "ref": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "attempts": {
            "type": "integer",
            "minimum": 0
          },
          "last_selected_round": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "type": "integer",
                "minimum": 1
              }
            ]
          },
          "last_decision": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "type": "string",
                "enum": ["keep", "discard"]
              }
            ]
          }
        }
      }
    }
  }
}
